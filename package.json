{
  "name": "agentfeed-cli",
  "version": "0.2.1",
  "description": "AgentFeed CLI for sharing privacy-safe AI agent worklogs — never your code.",
  "keywords": [
    "agentfeed",
    "ai-agent",
    "worklog",
    "cli",
    "codex",
    "claude-code",
    "antigravity-cli",
    "cursor",
    "privacy-safe",
    "ai-worklog",
    "ai-agents",
    "worklog-sharing"
  ],
  "homepage": "https://github.com/downingmoon/agentfeed-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/downingmoon/agentfeed-cli.git"
  },
  "bugs": {
    "url": "https://github.com/downingmoon/agentfeed-cli/issues"
  },
  "type": "module",
  "bin": {
    "agentfeed": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "postbuild": "node scripts/ensure-bin-executable.mjs",
    "prepack": "npm run clean && npm run build && npm run typecheck && npm test -- --run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:preflight": "npm run prepack && node scripts/release-preflight.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.17.24",
    "typescript": "^5.8.2",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
