{
  "name": "agentfeed-cli",
  "version": "0.2.0",
  "description": "AgentFeed CLI for collecting, reviewing, and publishing AI agent worklogs",
  "keywords": [
    "agentfeed",
    "ai-agent",
    "worklog",
    "cli",
    "codex",
    "claude-code",
    "gemini-cli",
    "cursor"
  ],
  "homepage": "https://agentfeed.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/downingmoon/agentfeed-cli.git"
  },
  "bugs": {
    "url": "https://github.com/downingmoon/agentfeed-cli/issues"
  },
  "type": "module",
  "bin": {
    "agentfeed": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "postbuild": "node scripts/ensure-bin-executable.mjs",
    "prepack": "npm run clean && npm run build && npm run typecheck && npm test -- --run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.0",
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^20.17.24",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
